{
  "name": "bsc-worker-production",
  "main": "src/index.ts",
  "workers_dev": true,
  "preview_urls": true,
  "compatibility_date": "2026-03-28",
  "account_id": "525bb177ae7306325d13269246769f50",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "kv_namespaces": [
    {
      "id": "7d8b2c94d0644e38a562cde510f500b0",
      "binding": "ORDER_STATE"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "blab-db-production",
      "database_id": "48479f91-eec7-4da2-b044-edaaf622f195"
    }
  ],
  "vars": {
    "LIFF_ID": "PLACEHOLDER_PRODUCTION_LIFF_ID",
    "LIFF_URL": "PLACEHOLDER_PRODUCTION_LIFF_URL"
  },
  "secrets_store_secrets": [
    {
      "binding": "LINE_CHANNEL_TOKEN",
      "store_id": "7e2896f1c5cf4e1eb80ef6c89f3024d4",
      "secret_name": "PLACEHOLDER_PRODUCTION_SECRET_NAME_LINE"
    },
    {
      "binding": "OPENROUTER_API_KEY",
      "store_id": "7e2896f1c5cf4e1eb80ef6c89f3024d4",
      "secret_name": "PLACEHOLDER_PRODUCTION_SECRET_NAME_OPENROUTER"
    },
    {
      "binding": "GROQ_API_KEY",
      "store_id": "7e2896f1c5cf4e1eb80ef6c89f3024d4",
      "secret_name": "PLACEHOLDER_PRODUCTION_SECRET_NAME_GROQ"
    }
  ],
  "env": {
    "test": {
      "name": "bsc-worker-test",
      "vars": {
        "LIFF_ID": "2009555608-DMioljsI",
        "LIFF_URL": "https://liff.line.me/2009555608-DMioljsI"
      },
      "secrets_store_secrets": [
        {
          "binding": "LINE_CHANNEL_TOKEN",
          "store_id": "7e2896f1c5cf4e1eb80ef6c89f3024d4",
          "secret_name": "LINE_MESSAGE_API_CHANNEL_BLAB"
        },
        {
          "binding": "OPENROUTER_API_KEY",
          "store_id": "7e2896f1c5cf4e1eb80ef6c89f3024d4",
          "secret_name": "OPENROUTER_API_KEY_BLAB"
        },
        {
          "binding": "GROQ_API_KEY",
          "store_id": "7e2896f1c5cf4e1eb80ef6c89f3024d4",
          "secret_name": "GROQ_API_KEY_BLAB"
        }
      ],
      "kv_namespaces": [
        {
          "id": "749b3a0cb19848e4b943b42d5898efff",
          "binding": "ORDER_STATE"
        }
      ],
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "blab-db-test",
          "database_id": "c0152835-7d42-4545-8cb4-6658dfc7e97d"
        }
      ]
    }
  }
}